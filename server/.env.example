# =============================================================================
# DocForge Server — Environment Configuration
# =============================================================================

# Server
HOST=0.0.0.0
PORT=8000

# =============================================================================
# AI Provider — any OpenAI-compatible endpoint
# =============================================================================
#
# DocForge uses the OpenAI chat completions API format.
# Point AI_BASE_URL to your AI server of choice:
#
# ── Self-hosted (no API key needed) ──────────────────────────────────
#
#   Ollama:
#     AI_BASE_URL=http://localhost:11434/v1
#     AI_MODEL=llama3
#
#   vLLM:
#     AI_BASE_URL=http://your-gpu-server:8000/v1
#     AI_MODEL=meta-llama/Llama-3-8b-chat-hf
#
#   LM Studio:
#     AI_BASE_URL=http://localhost:1234/v1
#     AI_MODEL=local-model
#
# ── Cloud providers (API key required) ───────────────────────────────
#
#   OpenAI:
#     AI_BASE_URL=https://api.openai.com/v1
#     AI_API_KEY=sk-your_openai_key
#     AI_MODEL=gpt-4o-mini
#
#   OpenRouter:
#     AI_BASE_URL=https://openrouter.ai/api/v1
#     AI_API_KEY=sk-or-your_openrouter_key
#     AI_MODEL=anthropic/claude-3-haiku
#

AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=
AI_MODEL=llama3

# Generation settings
MAX_TOKENS=4000
TEMPERATURE=0.7

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# Request limits
MAX_FILE_SIZE=500000
MAX_FILES=100

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
